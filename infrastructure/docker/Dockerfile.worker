# Worker container for async/background jobs (e.g. batch embeddings, doc ingestion)
# Uncomment and wire up if your app needs background task processing

FROM node:20-alpine AS builder
WORKDIR /app
COPY server/package*.json ./
RUN npm ci
COPY server/ .
RUN npm run build

FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/package*.json ./
RUN npm ci --omit=dev
# CMD ["node", "dist/worker.js"]
