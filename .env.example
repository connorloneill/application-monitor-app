# ── App ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:6110

# ── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# ── AWS ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AI / Bedrock ─────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.2
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# ── GitHub (for code retrieval) ──────────────────────────────────────────
GITHUB_TOKEN=

# ── Diagnosis ────────────────────────────────────────────────────────────
DIAGNOSIS_MAX_FILES=10
DIAGNOSIS_MAX_CONTENT_LENGTH=150000

# ── Database ─────────────────────────────────────────────────────────────
DYNAMODB_TABLE_PREFIX=myapp_
# or for SQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/myapp

# ── Storage ──────────────────────────────────────────────────────────────
S3_BUCKET_NAME=

# ── Problem Reports (shared external table) ──────────────────────────
PROBLEM_REPORTS_TABLE=problem_reports
PROBLEM_REPORTS_BUCKET=problem-reports-screenshots
